[Unit]
Description=ASAC - Sistema de Gestao de Materiais (FastAPI/Uvicorn)
After=network.target

[Service]
Type=simple
User=__USER__
Group=__GROUP__
WorkingDirectory=__PROJECT_DIR__
ExecStart=__PROJECT_DIR__/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000 --ssl-keyfile certs/key.pem --ssl-certfile certs/cert.pem
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
